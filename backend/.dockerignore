# Dependencies — will be installed fresh inside the container
node_modules/

# Environment variables — injected at runtime, never baked into the image
.env
.env.*
!.env.example

# Git files
.git/
.gitignore

# macOS junk
.DS_Store

# Uploaded files — volume-mounted at runtime
uploads/*
!uploads/.gitkeep

# Dev files
*.log
npm-debug.log*
reproduce_issue.js
