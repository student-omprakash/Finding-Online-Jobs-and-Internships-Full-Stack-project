# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Environment Files ───────────────────────────────────────────────────────
# NEVER commit .env — use .env.example instead
.env
.env.local
.env.production
.env.production.local
.env.development.local

# ─── Build Output ────────────────────────────────────────────────────────────
dist/
build/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Uploaded Files (Backend) ────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ─── Docker ──────────────────────────────────────────────────────────────────
# Do NOT ignore Dockerfile or docker-compose.yml — those are committed
# Ignore Docker override files used for local tweaks
docker-compose.override.yml

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
